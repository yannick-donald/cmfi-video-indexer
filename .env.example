APP_NAME=google-drive-video-inventory
LOG_LEVEL=INFO

# Path to OAuth client secret JSON downloaded from Google Cloud Console.
# Keep the real file OUT of git (see .gitignore).
GOOGLE_CREDENTIALS_PATH=credentials.json

# OAuth token cache (created automatically after login)
GOOGLE_TOKEN_PATH=cache/token.json

# SQLite index database path
DB_PATH=database/index.sqlite3

# Output paths
OUTPUT_DIR=output
EXCEL_OUTPUT_PATH=output/google_drive_video_inventory.xlsx

# Cache directory (downloads / transient artifacts)
CACHE_DIR=cache

# Drive scan options
INCLUDE_SHARED_DRIVES=true
INCLUDE_SHARED_WITH_ME=true
FOLLOW_SHORTCUTS=true

# Advanced metadata extraction
# Requires ffprobe installed and on PATH (recommended) OR set FFMPEG_BIN_DIR to ffmpeg/bin folder.
ENABLE_FFPROBE=true
FFMPEG_BIN_DIR=
MAX_DOWNLOAD_MB=0

# Concurrency
DOWNLOAD_WORKERS=4
FFPROBE_WORKERS=6

# If true, only update changed/new files (recommended)
INCREMENTAL=true

# Local web dashboard
WEB_HOST=127.0.0.1
WEB_PORT=8080
