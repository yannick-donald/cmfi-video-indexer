APP_NAME=google-drive-video-inventory
LOG_LEVEL=INFO

# Path to OAuth client secret JSON downloaded from Google Cloud Console.
# Keep the real file OUT of git (see .gitignore).
GOOGLE_CREDENTIALS_PATH=credentials.json

# OAuth token cache (created automatically after login)
GOOGLE_TOKEN_PATH=cache/token.json

# SQLite index database path
DB_PATH=database/index.sqlite3

# Output paths
OUTPUT_DIR=output
EXCEL_OUTPUT_PATH=output/google_drive_video_inventory.xlsx

# Cache directory (downloads / transient artifacts)
CACHE_DIR=cache

# Drive scan options
INCLUDE_SHARED_DRIVES=true
INCLUDE_SHARED_WITH_ME=true
FOLLOW_SHORTCUTS=true

# Advanced metadata extraction
# Requires ffprobe installed and on PATH (recommended) OR set FFMPEG_BIN_DIR to ffmpeg/bin folder.
ENABLE_FFPROBE=true
FFMPEG_BIN_DIR=
MAX_DOWNLOAD_MB=0

# Concurrency
DOWNLOAD_WORKERS=4
FFPROBE_WORKERS=6

# If true, only update changed/new files (recommended)
INCREMENTAL=true

# Local web dashboard
WEB_HOST=127.0.0.1
WEB_PORT=8080

# Public deployment mode
PUBLIC_DEMO=false
READ_ONLY=false
AUTO_SEED_DEMO=false

# Authentication
AUTH_REQUIRED=false
ALLOW_REGISTRATION=true
ADMIN_EMAIL=
ADMIN_PASSWORD=
SESSION_COOKIE_NAME=cmfi_session
SESSION_DAYS=14
SESSION_COOKIE_SECURE=false

# Require a six-digit code sent by e-mail before a new account can sign in.
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_MINUTES=15
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Server-side Google Drive access.
# Share only the intended Drive folders with the service account email.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Comma-separated application users allowed to launch Drive scans.
DRIVE_SCAN_EMAILS=
